{:paths ["src" "resources"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the kotoba-lang org of this workspace (transferred + renamed from
 ;; com-junkawasaki/langgraph-clj / com-junkawasaki/langchain-clj). This
 ;; repo is standalone (forkable outside the workspace); the :local/root
 ;; paths only resolve inside the monorepo checkout — a standalone fork
 ;; should override them with git coordinates.
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../../kotoba-lang/langgraph"}
        ;; langchain-store: the shared langchain.db store seam (EDN-blob
        ;; codec + identity schema + event-log helpers) that ~190 actors
        ;; hand-roll; pressureequip.store is an adopter (ADR-2607141600).
        io.github.kotoba-lang/langchain-store
        {:local/root "../../kotoba-lang/langchain-store"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "pressureequip.sim"]}
  :export {:main-opts ["-m" "pressureequip.export-run"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}
  ;; OPT-IN 3D visualization E2E (kami-engine canonical render-IR, ADR-2800000000
  ;; follow-on): renders `pressureequip.scene/unit->render-ir`'s output in a REAL
  ;; headless WebGL2 Chromium (kotoba-lang/playwright's kami.playwright bridge)
  ;; and reads back pixels, mirroring kotoba-lang/webgpu's own
  ;; test/playwright_mesh_test.clj pattern exactly. Deliberately isolated from
  ;; :test/:dev: NOT part of top-level :deps or the default "test" dir that
  ;; `clojure -M:test` scans, so a normal `clojure -M:test` run never needs
  ;; kami-engine's rendering stack on the classpath. Run with:
  ;;   clojure -M:visualize
  ;; Requires Node + a Playwright Chromium install reachable via NODE_PATH or
  ;; the npx cache (see scripts/pw_eval.cjs / kami.playwright's docstring) --
  ;; `npx playwright install chromium` if none is cached yet.
  :visualize
  {:extra-paths ["test-visualize"]
   :extra-deps {io.github.kotoba-lang/webgpu {:local/root "../../kotoba-lang/webgpu"}
                io.github.kotoba-lang/playwright {:local/root "../../kotoba-lang/playwright"}
                io.github.cognitect-labs/test-runner
                {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
   ;; kotoba-lang/physics-2d pins io.github.kotoba-lang/physics by git/sha while
   ;; webgpu's own transitive graph (host, webgpu itself) uses :local/root -- tools.deps
   ;; can't compare a :git and a :local/root coordinate for the same lib, so force the
   ;; workspace-local checkout (same pattern as this file's :dev override-deps).
   :override-deps {io.github.kotoba-lang/physics {:local/root "../../kotoba-lang/physics"}}
   :main-opts ["-m" "cognitect.test-runner" "-d" "test-visualize"]
   :exec-fn cognitect.test-runner.api/test
   :exec-args {:dirs ["test-visualize"]}}
  ;; OPT-IN tsukuru factory-discovery bridge tests (superproject
  ;; fictional-actor<->real-external-system bridge ADR --
  ;; `pressureequip.tsukuru-bridge`, `:discover/tsukuru-factory-
  ;; candidates`): exercises the bridge against a mock/stub `IHttp`
  ;; (never the real `tsukr8u0.etzhayyim.com`). Deliberately isolated
  ;; from :test, the SAME reasoning `:visualize` above already
  ;; documents: `io.github.kotoba-lang/atproto-client` is NOT part of
  ;; top-level :deps or the default "test" dir `clojure -M:test` scans,
  ;; so a normal `clojure -M:test` run never needs an AT-Proto client
  ;; on the classpath. Run with:
  ;;   clojure -M:tsukuru-bridge
  :tsukuru-bridge
  {:extra-paths ["test-tsukuru-bridge"]
   :extra-deps {io.github.kotoba-lang/atproto-client {:local/root "../../kotoba-lang/atproto-client"}
                io.github.cognitect-labs/test-runner
                {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
   :main-opts ["-m" "cognitect.test-runner" "-d" "test-tsukuru-bridge"]
   :exec-fn cognitect.test-runner.api/test
   :exec-args {:dirs ["test-tsukuru-bridge"]}}}}

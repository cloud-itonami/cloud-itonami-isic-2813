  {:part/id "part:condenser-coil" :part/name "Condenser coil" :part/qty 1}
  {:part/id "part:am-fan-housing" :part/name "Additively-manufactured condenser fan housing/impeller (integrated single-piece, metal powder-bed-fusion 3D print)" :part/qty 2}
  {:part/id "part:control-panel" :part/name "Control panel (NEMA/IP-rated enclosure)" :part/qty 1}
  {:part/id "part:piping" :part/name "Refrigerant piping (suction / discharge / liquid lines)" :part/qty 1}
  {:part/id "part:refrigerant-charge" :part/name "Refrigerant charge (R-448A)" :part/qty 1}
  {:part/id "part:frame" :part/name "Base frame / skid" :part/qty 1}
  {:part/id "part:vibration-isolators" :part/name "Vibration isolators (compressor mounts)" :part/qty 4}

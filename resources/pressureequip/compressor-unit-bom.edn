  {:part/id "part:motor-mount-bolt-set" :part/name "Electric motor mounting bolt/washer/nut set" :part/qty 4}
  {:part/id "part:condenser-coil-bolt-set" :part/name "Condenser coil bracket mounting bolt set" :part/qty 4}
